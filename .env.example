# Copie este arquivo para ".env" e preencha os valores antes de subir o container.
#
# Gere o hash bcrypt da senha de administrador com:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'SUA_SENHA_AQUI', bcrypt.gensalt(rounds=12)).decode())"
# (ou use o script generate_password_hash.py incluído no projeto)

# Obrigatório — hash bcrypt da senha usada para acessar o modo de gerenciamento
ADMIN_PASSWORD_HASH=

# Opcional — só defina como "false" se estiver rodando localmente SEM HTTPS
# (por padrão já assume que está atrás do Traefik com TLS, como no docker-compose.yml)
# HTTPS_ENABLED=true
